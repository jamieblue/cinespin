{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist/public/js",
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"incremental": false,
		"paths": {
			"shared/*": ["./src/shared/*"]
		}
	},
	"include": [
		"src/client",
		"src/shared/models",
		"src/shared/util",
		"src/shared/constants", 
        "src/shared/services"	]
}
